# Dev — relative base URL, Vite proxies /api, /health, /socket.io to the backend
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_DEV_PORT=3010

# Production (Vercel / `vite build`) — see .env.production
# API: https://feed-app-server.onrender.com/api/v1
#
# VITE_API_ORIGIN=https://feed-app-server.onrender.com
# VITE_API_BASE_URL=/api/v1
#
# Or set a full URL:
# VITE_API_BASE_URL=https://feed-app-server.onrender.com/api/v1

# Must match feed-app-server GOOGLE_CLIENT_ID / APPLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
