# Dev — relative base URL, Vite proxies /api, /health, /socket.io to the backend
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:3000
VITE_DEV_PORT=3010

# Production — call the API directly (set your deployed server URL)
# VITE_API_BASE_URL=https://api.example.com/api/v1
# VITE_API_ORIGIN=https://api.example.com

# Must match feed-app-server GOOGLE_CLIENT_ID / APPLE_CLIENT_ID
VITE_GOOGLE_CLIENT_ID=
VITE_APPLE_CLIENT_ID=
